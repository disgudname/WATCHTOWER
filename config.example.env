# ── Traccar ───────────────────────────────────────────────────────────────────
# URL of the local Traccar instance (default port 8082)
TRACCAR_URL=http://localhost:8082

# Traccar login credentials
TRACCAR_USER=admin
TRACCAR_PASS=yourpassword

# Device ID from Traccar — find it at /api/devices after logging in
TRACCAR_DEVICE_ID=1

# ── OpenWeatherMap ────────────────────────────────────────────────────────────
# Free-tier API key from openweathermap.org
OPENWEATHERMAP_API_KEY=your_owm_key_here

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_PORT=5000

# ── Database ──────────────────────────────────────────────────────────────────
# Path to the SQLite route history file (relative to project root)
DB_PATH=route.db

# ── Trip info ─────────────────────────────────────────────────────────────────
TRIP_NAME=2026 Reset Trip
TRIP_START_DATE=2026-06-16
TRIP_END_DATE=2026-06-23

# Name shown on the dark overlay ("SERENITY IS OFF-GRID")
VEHICLE_NAME=Serenity
